		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"runed": "^0.37.1",
		"shadcn-svelte": "^1.4.2",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-dnd-action": "^0.9.74",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
